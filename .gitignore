# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo

# Screenshots / images (not source assets)
*.png
!assets/icons/*.png

# Environment / secrets
.env

# iOS (generated by xcodegen)
ios/*.xcodeproj
ios/*.xcworkspace
ios/build/
ios/DerivedData/
